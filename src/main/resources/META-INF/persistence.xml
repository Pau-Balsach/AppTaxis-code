<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="TaxisPU" transaction-type="RESOURCE_LOCAL">

        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- Entidades -->
        <class>model.Admin</class>
        <class>model.Cliente</class>
        <class>model.Conductor</class>
        <class>model.Viaje</class>

        <exclude-unlisted-classes>true</exclude-unlisted-classes>

        <properties>
            <!-- Estas propiedades las sobreescribe JPAUtil en tiempo de ejecución -->
            <!-- con los valores de config.properties, así que no hace falta ponerlas aquí -->
        </properties>

    </persistence-unit>

</persistence>
