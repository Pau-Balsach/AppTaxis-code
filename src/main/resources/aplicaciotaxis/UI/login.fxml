<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<StackPane prefWidth="700.0" prefHeight="550.0" style="-fx-background-color: #1a1b2e;"
           xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ui.LoginController">
    <children>
        <VBox alignment="CENTER" spacing="20.0" maxWidth="400.0"
              style="-fx-background-color: white; -fx-background-radius: 15;">
            <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>
            <children>

                <Label text="App Taxis" textFill="#1a1b2e">
                    <font><Font name="System Bold" size="32.0"/></font>
                </Label>
                <Label text="Identifícate para continuar" textFill="#888888">
                    <font><Font size="13.0"/></font>
                </Label>

                <VBox spacing="15.0">
                    <children>
                        <TextField fx:id="txtEmail" promptText="Correo electrónico"
                                   style="-fx-background-color: #f8f9fa; -fx-padding: 10; -fx-border-color: #e0e0e0; -fx-border-radius: 5;" />
                        <PasswordField fx:id="txtPassword" promptText="Contraseña"
                                       style="-fx-background-color: #f8f9fa; -fx-padding: 10; -fx-border-color: #e0e0e0; -fx-border-radius: 5;" />
                    </children>
                </VBox>

                <VBox spacing="10.0" alignment="CENTER">
                    <children>
                        <Button onAction="#handlerLogin" text="INICIAR SESIÓN"
                                prefWidth="320.0" prefHeight="45.0"
                                style="-fx-background-color: #ffcc00; -fx-text-fill: #1a1b2e; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;" />

                        <Label fx:id="lblError" textFill="#cc0000" wrapText="true"
                               textAlignment="CENTER" minHeight="20.0">
                            <font><Font size="12.0"/></font>
                        </Label>

                        <Separator prefWidth="200.0">
                            <VBox.margin><Insets top="5" bottom="5"/></VBox.margin>
                        </Separator>

                        <Button onAction="#handlerIrARegistro" text="Crear una cuenta nueva"
                                prefWidth="320.0" prefHeight="40.0"
                                style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 13px; -fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-cursor: hand;" />
                    </children>
                </VBox>

            </children>
        </VBox>
    </children>
</StackPane>